# ╔══════════════════════════════════════════╗
# ║   THE UNKNOWN MAN — ENVIRONMENT VARS     ║
# ╚══════════════════════════════════════════╝
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── SERVER ─────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MONGODB ATLAS ───────────────────────────
# Get from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/the_unknown_man?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ── BCRYPT ──────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── CORS ────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000,https://your-frontend.vercel.app

# ── SEED CREDENTIALS (run: npm run seed) ───
# These become the two users in the database.
# Change them BEFORE seeding!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminSecurePass2026!
BHUMIKA_USERNAME=bhumika
BHUMIKA_PASSWORD=BhumikaSecure2026!

# ── RATE LIMITING ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10
